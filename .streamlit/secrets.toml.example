# Copy to .streamlit/secrets.toml and fill in values
# For Streamlit Community Cloud: add these in the app settings > Secrets

SUPABASE_URL = "https://tzvmdwjhzebgqxorkjms.supabase.co"
SUPABASE_ANON_KEY = "your_anon_key_here"
GROQ_API_KEY = "your_groq_key_here"
FORMSPREE_ID = "your_formspree_form_id"
POSTHOG_API_KEY = "your_posthog_key_here"

[auth]
redirect_uri = "https://your-app.streamlit.app/oauth2callback"
cookie_secret = "generate-a-random-32-char-string-here"

[[auth.providers]]
name = "google"
client_id = "your_google_oauth_client_id"
client_secret = "your_google_oauth_client_secret"
